# Copy to .env and fill in real values. Do NOT commit .env.

# ============================================================
# REQUIRED — both local dev and production
# ============================================================

# MongoDB connection string.
# Atlas free tier looks like: mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/?retryWrites=true
# Local install: mongodb://localhost:27017
MONGO_URL=
DB_NAME=training_slides

# Long random string for signing JWTs. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=

# Anthropic API key for AI summary + deck chat. Get one at console.anthropic.com.
# (Separate from your Claude.ai subscription — those don't include API access.)
ANTHROPIC_API_KEY=

# ============================================================
# STORAGE — pick local or r2
# ============================================================

# "local" stores files under STORAGE_DIR. Fine for development.
# "r2"   stores files in a Cloudflare R2 bucket. Required for production
#        because most cheap PaaS plans wipe local disk on every restart.
STORAGE_BACKEND=local

# --- if STORAGE_BACKEND=local ---
# STORAGE_DIR=C:\path\to\uploads        # default: backend/data/uploads

# --- if STORAGE_BACKEND=r2 ---
# Cloudflare account ID (shown on the R2 page sidebar).
# R2_ACCOUNT_ID=
# Bucket name + token from R2 → Manage R2 API Tokens (scope: Object Read & Write).
# R2_BUCKET_NAME=slidevault-files
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# Optional override (otherwise built from R2_ACCOUNT_ID).
# R2_ENDPOINT_URL=https://<account>.r2.cloudflarestorage.com

# ============================================================
# CORS + cookies
# ============================================================

# Comma-separated origins allowed by CORS. Must NOT include "*" because the app
# uses credentialed cookies.
#   Local dev:  http://localhost:3000
#   Production: https://<your-frontend>.vercel.app
CORS_ORIGINS=http://localhost:3000

# Cookie security. Production (HTTPS): keep both at default. Local HTTP dev:
# set COOKIE_SECURE=false.
COOKIE_SECURE=true

# Cookie SameSite policy. Local dev or same-domain prod: "lax".
# Cross-origin prod (Vercel frontend + Render backend): "none" (requires Secure).
COOKIE_SAMESITE=lax

# ============================================================
# OPTIONAL
# ============================================================

APP_NAME=training-slides

# Override the Claude model (default tracks Sonnet 4.5).
# CLAUDE_MODEL=claude-sonnet-4-5-20250929

# Optional one-time admin seed. Created on first startup ONLY IF no user with
# this email exists. Password is NEVER reset on subsequent startups.
# Leave blank to skip seeding entirely (register through the UI instead).
ADMIN_EMAIL=
ADMIN_PASSWORD=
