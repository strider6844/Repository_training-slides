# Copy to .env and fill in real values. Do NOT commit .env.

# --- Required ---
MONGO_URL=mongodb://localhost:27017
DB_NAME=training_slides

# Use a long random string. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=

# Emergent integrations key (used for object storage + Claude LLM calls)
EMERGENT_LLM_KEY=

# --- Optional ---
APP_NAME=training-slides

# Comma-separated origins allowed by CORS. Must NOT include "*" because the app
# uses credentialed cookies. Set to your real frontend URL(s) in production.
CORS_ORIGINS=http://localhost:3000

# Set to "false" only for local HTTP development. Production must keep this true
# so auth cookies are sent only over HTTPS.
COOKIE_SECURE=true

# Optional one-time admin seed. The user is created on first startup ONLY IF
# no user with this email exists. The password is NEVER reset on subsequent
# startups — change it through the UI after first login and it stays changed.
# Leave both blank to skip seeding entirely.
ADMIN_EMAIL=
ADMIN_PASSWORD=
